{
  "name": "inkdrift",
  "version": "1.0.0",
  "description": "A minimal, focused task manager for Mac",
  "main": "main.js",
  "author": "",
  "license": "ISC",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "keywords": [
    "todo",
    "electron",
    "desktop"
  ],
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "dotenv": "^16.0.0"
  },
  "devDependencies": {
    "electron": "^39.2.7",
    "electron-builder": "^26.4.0"
  },
  "build": {
    "appId": "com.inkdrift.app",
    "productName": "InkDrift",
    "mac": {
      "category": "public.app-category.productivity",
      "target": {
        "target": "dmg",
        "arch": ["universal"]
      },
      "icon": "icon.icns"
    },
    "dmg": {
      "title": "InkDrift",
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    }
  }
}
